{
  "name": "dokra",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest --project unit",
    "test:e2e": "vitest --project e2e",
    "test:nuxt": "vitest --project nuxt",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply dokra-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply dokra-db --remote",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.971.0",
    "@aws-sdk/s3-request-presigner": "^3.971.0",
    "@nuxt/fonts": "0.12.1",
    "@nuxt/hints": "1.0.0-alpha.5",
    "@nuxt/icon": "2.1.1",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "0.13.2",
    "@tailwindcss/vite": "^4.1.18",
    "@unhead/vue": "^2.1.1",
    "better-auth": "^1.4.10",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.2.2",
    "pdfjs-dist": "^5.4.530",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.26",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260103.0",
    "@nuxt/test-utils": "3.21.0",
    "@vitest/coverage-v8": "^4.0.17",
    "@vue/test-utils": "^2.4.6",
    "daisyui": "^5.5.14",
    "drizzle-kit": "^0.31.8",
    "happy-dom": "^20.0.11",
    "playwright-core": "^1.57.0",
    "vitest": "^4.0.16",
    "wrangler": "4.59.1"
  }
}
