{
  "name": "dokra-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Dokra Document Management System - Monorepo",
  "scripts": {
    "dev": "pnpm --filter dokra dev",
    "build": "pnpm --filter dokra build",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @dokra/database db:generate",
    "db:migrate": "pnpm --filter dokra db:migrate",
    "db:migrate:prod": "pnpm --filter dokra db:migrate:prod",
    "db:studio": "pnpm --filter @dokra/database db:studio",
    "deploy:app": "pnpm --filter dokra deploy",
    "deploy:worker": "pnpm --filter dokra-ocr-consumer deploy",
    "deploy:all": "pnpm deploy:app && pnpm deploy:worker"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
